# 应用配置
APP_NAME=AI设计任务管理系统
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# 服务器配置
HOST=0.0.0.0
PORT=8000

# ========== 数据库配置 ==========
# 方式1: 直接指定完整连接串（设置后忽略下方 DB_* 字段）
# DATABASE_URL=mysql+aiomysql://user:pass@rm-xxx.mysql.rds.aliyuncs.com:3306/dbname?charset=utf8mb4
DATABASE_URL=

# 方式2: 结构化配置（推荐，当 DATABASE_URL 为空时生效）
DB_TYPE=sqlite
# DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=app
DB_USER=
DB_PASSWORD=
DB_CHARSET=utf8mb4

# 连接池配置（仅 MySQL/RDS 生效）
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=True

# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS 配置
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,application/zip,application/pdf

# 阿里云 OSS 配置
OSS_ENABLED=False
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_ENDPOINT=

# 阿里云短信服务（dysmsapi）
SMS_ENABLED=False
SMS_ACCESS_KEY_ID=your-aliyun-ak
SMS_ACCESS_KEY_SECRET=your-aliyun-sk
SMS_SIGN_NAME=你的短信签名
SMS_TEMPLATE_CODE=你的短信模板CODE(如SMS_123456)
SMS_CODE_LENGTH=6
SMS_VALID_TIME=300

# 邮件配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-qq-email@qq.com
SMTP_PASSWORD=your-qq-smtp-auth-code
SMTP_FROM=your-qq-email@qq.com
SMTP_FROM_NAME=AI设计任务管理系统

# API 限流配置
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# 初始管理员账户（部署时请修改）
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=123456
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PHONE=13800000000
